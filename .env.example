# SSH Connection Configuration
SSH_HOST=your-server-ip
SSH_PORT=22
SSH_USERNAME=your-ssh-username
SSH_PASSWORD=your-ssh-password
SSH_PRIVATE_KEY=

# Target Paths on Remote Server
TARGET_PATH=~/workspace/geoserver-docker/geoserver_data/uploads

# Web Interface Authentication
AUTH_USERNAME=admin
AUTH_PASSWORD=your-secure-password

# Session Configuration (must be at least 32 characters)
SESSION_SECRET=your-super-secret-key-for-session-encryption-min-32-chars

# Permission / sudo fallback (optional)
SUDO_ENABLED=true
SUDO_PASSWORD=
TEMP_UPLOAD_PATH=/tmp
